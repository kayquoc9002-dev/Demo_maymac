{
  "info": {
    "name": "MayMac Pro — API Collection",
    "_postman_id": "maymac-api-collection-v1",
    "description": "Toàn bộ API backend: Auth, HR, Khách hàng, Nhà phân phối, Đối tác",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Đăng nhập",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('✅ Token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },

    {
      "name": "👥 HR — Nhân viên",
      "item": [
        {
          "name": "Lấy danh sách nhân viên",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/hr/employees?q=&limit=20",
              "host": ["{{base_url}}"], "path": ["hr", "employees"],
              "query": [
                { "key": "q", "value": "", "description": "Tìm theo tên" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Thêm nhân viên",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyễn Văn A\",\n  \"gender\": \"Nam\",\n  \"phone\": \"0901234567\",\n  \"email\": \"nva@maymac.pro\",\n  \"startDate\": \"2024-01-01\",\n  \"departmentId\": 1,\n  \"positionId\": 1\n}"
            },
            "url": { "raw": "{{base_url}}/hr/employees", "host": ["{{base_url}}"], "path": ["hr", "employees"] }
          }
        },
        {
          "name": "Cập nhật nhân viên",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyễn Văn A (Updated)\",\n  \"phone\": \"0909999999\",\n  \"email\": \"nva_new@maymac.pro\",\n  \"departmentId\": 1,\n  \"positionId\": 2\n}"
            },
            "url": { "raw": "{{base_url}}/hr/employees/:id", "host": ["{{base_url}}"], "path": ["hr", "employees", ":id"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Nghỉ việc nhân viên",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resignDate\": \"2024-12-31\",\n  \"reason\": \"Xin nghỉ việc\"\n}"
            },
            "url": { "raw": "{{base_url}}/hr/employees/:id/resign", "host": ["{{base_url}}"], "path": ["hr", "employees", ":id", "resign"], "variable": [{ "key": "id", "value": "1" }] }
          }
        }
      ]
    },

    {
      "name": "🏢 HR — Phòng ban",
